# the base url of the application, the default is "/"
# if use a sub directory, it must be end with "/", like "/admin/" but not "/admin"
VITE_BASE_URL=/markflow/

VITE_APP_TITLE=MarkFlow

VITE_APP_DESC=Markdown Workspace

# the prefix of the icon name
VITE_ICON_PREFIX=icon

# the prefix of the local svg icon component, must include VITE_ICON_PREFIX
# format {VITE_ICON_PREFIX}-{local icon name}
VITE_ICON_LOCAL_PREFIX=icon-local

# auth route mode: static ｜ dynamic
# static: routes from generatedRoutes + role filter (recommended for ai-server)
# dynamic: sidebar/routes from menu API or VITE_USE_MENU_MOCK
VITE_AUTH_ROUTE_MODE=static

# Y = use menu-mock for dynamic routes; N = call backend route API (when available)
VITE_USE_MENU_MOCK=N

# Y = skip login and use demo token in dev (local UI only)
VITE_DEV_BYPASS_AUTH=N

# static auth route home
VITE_ROUTE_HOME=home

# default menu icon
VITE_MENU_ICON=mdi:menu

# whether to enable http proxy when is dev mode
VITE_HTTP_PROXY=Y

# vue-router mode: hash | history | memory
VITE_ROUTER_HISTORY_MODE=history

# success codes in response body (comma-separated, no spaces) — ai-server: 200, 201
VITE_SERVICE_SUCCESS_CODE=200,201

# logout codes when already logged in (not for wrong password on login form)
VITE_SERVICE_LOGOUT_CODES=1203,1204,1205

# modal logout codes in response body
VITE_SERVICE_MODAL_LOGOUT_CODES=1206,1207,2000

# token expired but refreshable — ai-server TOKEN_EXPIRED
VITE_SERVICE_EXPIRED_TOKEN_CODES=1202

# when the route mode is static, the defined super role
VITE_STATIC_SUPER_ROLE=R_SUPER

# sourcemap
VITE_SOURCE_MAP=N

# Used to differentiate storage across different domains
VITE_STORAGE_PREFIX=SOY_

# used to control whether the program automatically detects updates
VITE_AUTOMATICALLY_DETECT_UPDATE=Y

# Remove console statements in builds (Y/N)
# Default is N for development, Y for production builds
# When Y, console.log, console.warn, console.error, and debugger statements are removed from build
VITE_DROP_CONSOLE=N

# show proxy url log in terminal
VITE_PROXY_LOG=Y

# used to control whether to launch editor
# by the way, this plugin is only available in dev mode, not in build mode
VITE_DEVTOOLS_LAUNCH_EDITOR=cursor

# backend service base url
VITE_SERVICE_BASE_URL=http://localhost:3000
