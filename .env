# =============================================================================
# MarkFlow 本地开发环境变量（默认由 `pnpm dev` 加载；实际还会合并 .env.test，见 package.json）
# 说明：带 VITE_ 前缀的变量会注入前端代码，修改后需重启 dev 服务
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基础信息
# -----------------------------------------------------------------------------

# 应用部署的基础路径（影响打包资源与路由 base）
# - 根路径部署：/
# - 子目录部署：必须以 / 结尾，例如 /markflow/（不要写成 /markflow）
# - 与 Nginx / GitHub Pages 的 location 或 pages 子路径保持一致
VITE_BASE_URL=/markflow/

# 浏览器标签页标题、登录页等展示的应用名称
VITE_APP_TITLE=MarkFlow

# 应用副标题或描述文案（部分页面展示）
VITE_APP_DESC=Markdown Workspace

# -----------------------------------------------------------------------------
# 图标（Iconify + 本地 SVG）
# -----------------------------------------------------------------------------

# 在线 Iconify 图标名前缀，组件内引用形如：icon:mdi:home
VITE_ICON_PREFIX=icon

# 本地 SVG 图标组件前缀，必须包含上面的 VITE_ICON_PREFIX
# 最终组件名格式：{VITE_ICON_PREFIX}-{VITE_ICON_LOCAL_PREFIX 去掉 icon- 部分}-{文件名}
# 示例：icon-local-custom → 对应 src/assets/svg-icon 下的图标
VITE_ICON_LOCAL_PREFIX=icon-local

# 侧栏菜单未单独配置图标时的默认 Iconify 图标
VITE_MENU_ICON=mdi:menu

# -----------------------------------------------------------------------------
# 路由与鉴权
# -----------------------------------------------------------------------------

# 鉴权路由加载模式
# - static（推荐，对接 ai-server）：
#     路由表由前端 elegant-router 代码生成，按用户角色过滤可见菜单；
#     不依赖后端「菜单路由」接口，与 ai-server 全局前缀 /api/admin/* 配合即可
# - dynamic（推荐，联调 ai-server）：
#     登录后从 ai-server GET /api/admin/menus/user-routes 拉取路由与侧栏
VITE_AUTH_ROUTE_MODE=dynamic

# 是否跳过真实登录（仅本地无后端、纯 UI 演示）
# - N（默认）：走 /api/admin/auth/login-step1、login-step2，需 ai-server 已启动
# - Y：自动写入演示 token，不请求 /users/me；与 GitHub Pages 静态站不同，勿在生产开启
# 注意：必须显式设为 Y 才生效，开发环境不会默认绕过
VITE_DEV_BYPASS_AUTH=N

# static 模式下登录后默认进入的路由 name（与 src/router/elegant 中路由 key 一致）
VITE_ROUTE_HOME=home

# Vue Router 历史模式
# - history：无 #，需服务器 fallback 到 index.html（生产常用）
# - hash：URL 带 #，无需服务端配置
# - memory：多用于 SSR/测试，一般不用
VITE_ROUTER_HISTORY_MODE=history

# -----------------------------------------------------------------------------
# 后端地址与开发代理
# -----------------------------------------------------------------------------

# 后端 API 根地址（NestJS ai-server 默认 http://localhost:3000，全局前缀 /api）
# - 开发且 VITE_HTTP_PROXY=Y 时：浏览器请求走 /proxy-default，由 Vite 转发到此地址
# - 开发且 VITE_HTTP_PROXY=N 时：前端直接请求该 URL（需后端配置 CORS）
# - Docker 只起了 MySQL/Redis 时：仍需在宿主机 pnpm run start:dev 启动 API，端口填 3000
VITE_SERVICE_BASE_URL=http://localhost:3000

# 开发模式是否启用 Vite HTTP 代理（仅 pnpm dev 生效）
# - Y：解决跨域，请求形如 /proxy-default/api/admin/...
# - N：直连 VITE_SERVICE_BASE_URL
VITE_HTTP_PROXY=Y

# 是否在终端打印代理转发的真实 URL（排查接口是否打到后端时建议 Y）
VITE_PROXY_LOG=Y

# -----------------------------------------------------------------------------
# 业务状态码（与 ai-server 响应体 code 字段对齐，勿填 HTTP 状态码如 401）
# 成功响应格式：{ data, code: 200|201, message, timestamp }
# 失败响应格式：{ code, message, details?, timestamp, path? }
# 处理逻辑见：src/service/request/policies/mainRequestPolicies.ts、errorHandler.ts
# -----------------------------------------------------------------------------

# 视为「请求成功」的业务 code，逗号分隔、无空格
# ai-server 成功码一般为 200（查询/更新）、201（创建）
VITE_SERVICE_SUCCESS_CODE=200,201

# 已登录用户持有 token 时，收到下列 code 会静默登出并跳转登录页
# 不要包含 1200/1201（用户名密码错误，仅登录页 toast，不登出）
# 1203 TOKEN_INVALID | 1204 TOKEN_REVOKED | 1205 SESSION_EXPIRED
VITE_SERVICE_LOGOUT_CODES=1203,1204,1205

# 已登录时收到下列 code 先弹窗说明原因，用户确认后再登出
# 1206 账号锁定 | 1207 账号禁用 | 2000 账号黑名单
VITE_SERVICE_MODAL_LOGOUT_CODES=1206,1207,2000

# Access Token 过期但可刷新：自动调 /api/admin/auth/refresh，成功则重试原请求
# ai-server：1202 TOKEN_EXPIRED（HTTP 可能为 401，由全局封装统一解析）
VITE_SERVICE_EXPIRED_TOKEN_CODES=1202

# -----------------------------------------------------------------------------
# 构建、调试与其它
# -----------------------------------------------------------------------------

# 生产构建是否输出 sourcemap（Y/N），开发模式不受此项影响
VITE_SOURCE_MAP=N

# 本地 Storage 键名前缀（token、主题等），多环境同域部署时可区分数据
VITE_STORAGE_PREFIX=SOY_

# 是否在运行时检测新版本并提示刷新（Y/N）
VITE_AUTOMATICALLY_DETECT_UPDATE=Y

# 生产构建是否剔除 console / debugger（Y/N）
# 开发建议 N；pnpm build 时可在 .env.prod 等覆盖为 Y
VITE_DROP_CONSOLE=N

# Vue DevTools 中「在编辑器中打开」使用的 IDE
# 可选：cursor | code | webstorm 等，仅 dev 模式
VITE_DEVTOOLS_LAUNCH_EDITOR=cursor

# 可选：自建 Iconify API，内网环境可指向私有服务
# VITE_ICONIFY_URL=https://api.iconify.design
