# =============================================================================
# GitHub Pages 静态部署（pnpm deploy 等）
# =============================================================================

# 开启静态演示：不请求远程 API，使用内置演示账号与静态路由
VITE_STATIC_DEMO=Y

# 留空表示同源相对路径，避免 Pages 上跨域请求失败
VITE_SERVICE_BASE_URL=
