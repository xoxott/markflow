# =============================================================================
# 生产构建环境（pnpm build:prod 等使用，按项目脚本为准）
# =============================================================================

# 生产环境主 API 地址；当前示例为 Apifox Mock，上线请改为真实 ai-server 域名
VITE_SERVICE_BASE_URL=https://mock.apifox.cn/m1/3109515-0-default

# 生产环境其它后端（JSON）
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9529"
}`

# 生产包移除 console，减小体积并避免泄露调试信息
VITE_DROP_CONSOLE=Y
