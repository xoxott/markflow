# =============================================================================
# Vite mode=test 专用（pnpm dev、pnpm build:test 会加载并覆盖 .env 同名变量）
# =============================================================================

# 开发代理转发的目标地址，须与正在运行的 ai-server 端口一致
# Docker 仅启动 MySQL/Redis/MinIO 时，请在 ai-server 目录执行 pnpm run start:dev（默认 3000）
VITE_SERVICE_BASE_URL=http://localhost:3000

# 其它后端基址（JSON5 格式），供 demoRequest 等多后端场景使用
# key「demo」对应 src 中 otherBaseURL.demo
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9528"
}`

# test 模式构建是否保留 console，便于联调
VITE_DROP_CONSOLE=N
