# backend service base url (pnpm dev uses --mode test; proxy target = ai-server)
VITE_SERVICE_BASE_URL=http://localhost:3000

# other backend service base url, test environment
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9528"
}`

# Keep console statements in test builds for debugging
VITE_DROP_CONSOLE=N
