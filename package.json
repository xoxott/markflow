{
  "name": "markdown-preview-demo",
  "type": "module",
  "version": "1.3.13",
  "description": "Vue3、Vite6、TypeScript、NaiveUI and UnoCSS Utils Markdown",
  "author": {
    "name": "yangtao",
    "email": "212920320@qq.com",
    "url": "https://xoxott.github.io"
  },
  "license": "MIT",
  "homepage": "https://xoxott.github.io/markdown-preview-demo",
  "repository": {
    "url": "https://xoxott.github.io/markdown-preview-demo.git"
  },
  "bugs": {
    "url": "https://xoxott.github.io/markdown-preview-demo/issues"
  },
  "keywords": [
    "Vite6",
    "TypeScript",
    "naive-ui",
    "naive-ui-admin",
    "UnoCSS",
    "markdown",
    "markdown-it-plugin",
    "markdown-render-vnode"
  ],
  "engines": {
    "node": ">=18.20.0",
    "pnpm": ">=8.7.0"
  },
  "scripts": {
    "bench": "vitest bench",
    "bench:flow": "vitest bench src/components/flow/__tests__/performance.bench.ts",
    "bench:compare": "vitest bench src/components/flow/__tests__/flow-vs-vueflow.bench.ts",
    "test:flow-compare": "vitest run src/components/flow/__tests__/flow-vs-vueflow.mount.test.ts",
    "build": "vite build --mode prod",
    "build:gh": "vite build --mode gh",
    "build:check": "vite build --mode prod && node -e \"require('./build/scripts/check-console-drop').checkConsoleStatements()\"",
    "build:test": "vite build --mode test",
    "cleanup": "sa cleanup",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "deploy": "pnpm build:gh && gh-pages -d dist --dotfiles",
    "dev": "vite --mode test",
    "dev:prod": "vite --mode prod",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen-route": "sa gen-route",
    "i18n:convert": "node convert-locales.mjs",
    "lint": "eslint src --fix",
    "lint:format": "prettier --write . && eslint . --fix --ext .ts,.tsx,.js,.jsx,.vue",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "release": "sa release",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "update-pkg": "sa update-pkg"
  },
  "dependencies": {
    "@better-scroll/core": "2.5.1",
    "@iconify/vue": "5.0.0",
    "@primer/css": "^22.0.0",
    "@shikijs/monaco": "^3.4.2",
    "@suga/ai-commands": "workspace:*",
    "@suga/axios": "workspace:*",
    "@suga/color": "workspace:*",
    "@suga/hooks": "workspace:*",
    "@suga/markdown-it-render-vnode": "workspace:*",
    "@suga/markdown-it-render-vnode-vue": "workspace:*",
    "@suga/markdown-it-task-lists": "workspace:*",
    "@suga/materials": "workspace:*",
    "@suga/utils": "workspace:*",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/tabler": "^0.13.0",
    "@vscode/markdown-it-katex": "^1.1.2",
    "@vue/repl": "git+https://github.com/xoxott/repl.git#swich-npm-registry",
    "@vueuse/core": "13.1.0",
    "clipboard": "2.0.11",
    "d3": "^7.9.0",
    "dayjs": "1.11.13",
    "defu": "6.1.4",
    "echarts": "5.6.0",
    "github-markdown-css": "^5.8.1",
    "highlight.js": "^11.11.1",
    "immer": "^11.1.3",
    "json5": "2.2.3",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.0",
